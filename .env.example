# Thesis — configuration (copy to .env and fill in what you have; .env is gitignored).
# Every key is OPTIONAL: with none set, keyed providers run in fixture mode or
# return disclosed gaps, FINRA and the FRED CSV fallback remain keyless, and the
# pipeline still produces a valid data-only report. SEC EDGAR additionally needs
# the declared contact configured below before its live acquisition path runs.

# --- API keys -----------------------------------------------------------------

# Financial Modeling Prep — Ultimate plan key.
# Without it, the FMP client serves bundled fixtures (fixtures/fmp/…).
FMP_API_KEY=

# Anthropic — enables the bull/bear/judge LLM passes + web search.
# Without it, the pipeline degrades to a data-only report (Stage A/B only).
ANTHROPIC_API_KEY=

# FRED — free key from https://fred.stlouisfed.org/docs/api/api_key.html
# The macro dashboard. A keyless fredgraph.csv fallback exists for smoke tests.
FRED_API_KEY=

# Finnhub — free-tier key. Insider sentiment (MSPR) + optional sector modules.
FINNHUB_API_KEY=

# --- SEC EDGAR contact --------------------------------------------------------

# SEC EDGAR is keyless but REQUIRES a declared contact in the User-Agent of every
# request. Set this to your own contact — format "Your Name your-email@example.com".
# If it is unset or still a placeholder, live EDGAR acquisition is disabled and
# the missing source is disclosed in the report rather than sending an anonymous
# request. Configure a real identity before using any live SEC data path.
EDGAR_CONTACT=

# --- Analysis pipeline tuning -------------------------------------------------

# Model used for the analysis pipeline (bull/bear/judge passes).
# "auto" resolves at runtime to the best model available to your key, in
# preference order claude-opus-4-8 -> claude-sonnet-5 -> claude-fable-5. Fable 5
# is demoted (safety-classifier false positives on finance content, longer
# turns) — set an explicit model ID to opt into it as a "deep-dive" mode. The
# in-app Settings page overrides this without a restart.
#
# (The former VERIFY_MODEL var was removed: verification is deterministic
# numeric-source tracing and never calls a model.)
ANALYSIS_MODEL=auto

# Reasoning effort for the LLM passes: low | medium | high | xhigh | max.
# Thinking tokens are billed as output and are the largest cost component per
# report, so this is the main cost/quality knob. Defaults to "high"; also
# overridable on the Settings page. An unrecognized value degrades to "high".
ANALYSIS_EFFORT=high

# --- Local database (optional overrides) --------------------------------------

# The SQLite DB defaults to the OS app-data directory (so its WAL/SHM writes do
# not trigger Next.js dev-server rebuilds from inside the repo). Override the
# file with THESIS_DB_PATH, or just the directory with THESIS_DATA_DIR.
# THESIS_DB_PATH=
# THESIS_DATA_DIR=
